# =================================================================
# 여월농장 (yeowolgarden) - Environment Variables Template
# =================================================================
# Copy this file to .env.local and fill in actual values.
# .env.local is in .gitignore and will NOT be committed.

# ─── Public (브라우저 노출 가능) ───
NEXT_PUBLIC_SITE_URL=https://yeowolfarm.netlify.app
NEXT_PUBLIC_FARM_LAT=37.514173
NEXT_PUBLIC_FARM_LNG=126.793019
NEXT_PUBLIC_FARM_ADDRESS=경기도 부천시 오정구 여월동 112
NEXT_PUBLIC_NAVER_MAP_PLACE_ID=2003003971
NEXT_PUBLIC_GA_ID=

# ─── Turso DB (서버 전용) ───
# Turso 대시보드 → Database → Connect 에서 복사
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=

# ─── NextAuth (서버 전용) ───
NEXTAUTH_URL=https://yeowolfarm.netlify.app
# 생성: openssl rand -base64 32  또는  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=

# ─── Admin (서버 전용) ───
ADMIN_ID=adminyeowol
# 생성: pnpm tsx scripts/hash-password.ts '<비밀번호>'
ADMIN_PASSWORD_HASH=

# ─── 사업 정보 (UI 표시용, 서버 ENV로 관리) ───
BANK_INFO_DISPLAY=농축협 351-1352-647143 농업회사법인 (유)호정
OPERATOR_PHONE=
